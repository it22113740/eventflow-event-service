# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development
SERVICE_NAME=eventflow-event-service

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: mongodb://localhost:27017/eventflow-events
# Docker Compose: mongodb://mongo:27017/eventflow-events
MONGO_URI=mongodb://localhost:27017/eventflow-events

# ── Inter-service ─────────────────────────────────────────────────────────────
# URL of the User Service used to validate JWTs
USER_SERVICE_URL=http://user-service:3001
# URL of the Notification Service for new event broadcasts
NOTIFICATION_SERVICE_URL=http://notification-service:3004

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
